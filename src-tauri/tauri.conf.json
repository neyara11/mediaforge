{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaForge",
  "version": "0.1.0",
  "identifier": "com.mediaforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MediaForge",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREMkEwMkU0NzAyMDg3OTkKUldTWmh5Qnc1QUlxM1lEck5DaHBiUFp3NnlqanZXTjFYVHgyeE5uVU05VFFKUWJ1Q1pOMEhtVXYK",
      "endpoints": [
        "https://github.com/neyara11/mediaforge/releases/latest/download/latest.json"
      ]
    }
  }
}
